{
  "manifest_version": 3,
  "name": "Tuply - DatoCMS AI Assistant",
  "description": "Tuply, your advanced AI assistant for DatoCMS.",
  "version": "1.0.0",
  "icons": {
    "16": "store-assets/icon-16.png",
    "48": "store-assets/icon-48.png",
    "128": "store-assets/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.admin.datocms.com/*"],
      "js": ["assets/lottie.min.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/mascot-idle.json", "assets/mascot-wave.json", "assets/mascot-talk.json", "assets/mascot-write.json", "assets/mascot-celebrate.json", "assets/mascot-think.json", "assets/mascot-eureka.json", "assets/mascot-toss.json", "assets/mascot-proud.json", "assets/mascot-intro.json", "assets/mascot-sad.json"],
      "matches": ["https://*.admin.datocms.com/*"]
    }
  ]
}
